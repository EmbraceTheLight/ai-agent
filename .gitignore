# =========================

.idea/
*.iml
*.iws
*.ipr

# =========================
# Visual Studio Code
# =========================

.vscode/

# =========================
# 操作系统生成文件
# =========================

# Windows
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

# =========================
# 日志和临时文件
# =========================

*.log
logs/
log/

*.tmp
*.temp
*.swp
*.swo
*.bak

tmp/
temp/
.cache/

# =========================
# 本地配置和敏感信息
# =========================

.env
.env.*
!.env.example

*.local
config.local.*
application-local.*

