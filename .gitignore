# =========================
# Go 构建产物
# =========================

# 可执行文件
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go 测试生成的二进制文件
*.test

# Go 性能分析文件
*.prof
*.pprof

# 覆盖率文件
*.out
coverage.*
coverage/

# 常见构建输出目录
bin/
build/
dist/
out/

